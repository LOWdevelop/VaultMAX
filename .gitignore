# dependencies
node_modules/

# build output
dist/

# environment variables (never commit real keys)
.env

# local MCP config — contains a real API key, never commit
.mcp.json

# SQLite database (generated at runtime)
vaultmax.db
vaultmax.db-shm
vaultmax.db-wal
*.backup

# vault content is local — each user has their own
vaults/*
!vaults/.gitkeep

# internal spec
SPEC_1.md
